# Cloudflare Tunnel + Access
CF_TUNNEL_TOKEN=<tunnel token from Zero Trust -> Tunnels>
CF_ACCESS_CLIENT_ID=<service token client ID from Zero Trust -> Access -> Service Auth>
CF_ACCESS_CLIENT_SECRET=<service token client secret>
CF_TUNNEL_HOSTNAME=n8n-ssh.yourdomain.com

# SSH
DEPLOY_SSH_USER=root
DEPLOY_SSH_KEY=<ed25519 private key (generate inside Docker)>
